---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout
  title="${singlePage.spec.title + ' - ' + site.title}"
  setOGTypeArticle={true}
  showToc={true}
>
  <Fragment slot="head">
    <title th:text="${singlePage.spec.title + ' - ' + site.title}"></title>
  </Fragment>

  <article class="card-base relative z-10 mb-4 w-full px-6 pb-8 pt-7 md:px-9">
    <h1
      class="onload-animation relative mb-5 text-3xl font-bold text-black/90 transition before:absolute before:-left-4.5 before:top-3 before:h-5 before:w-1 before:rounded-md before:bg-(--primary) dark:text-white/90 md:text-[2.25rem]/[2.75rem]"
      th:text="${singlePage.spec.title}"
    >
      Page title
    </h1>
    <div
      id="content"
      class="custom-md markdown-content onload-animation prose prose-base max-w-none! dark:prose-invert!"
      th:classappend="| ${theme.config?.post?.contentDisplay?.content_size} ${theme.config?.post?.contentDisplay?.content_theme}|"
      th:utext="${singlePage.content.content}"
    >
    </div>
  </article>
  <div
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
    id="comment"
    th:if="${haloCommentEnabled && (singlePage.spec.allowComment != false)}"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="content.halo.run" kind="SinglePage" th:attr="name=${singlePage.metadata.name}" />'}
    />
  </div>
</MainGridLayout>
