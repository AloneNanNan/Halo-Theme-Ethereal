---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="|#{page.categories.title} - ${site.title}|">
  <Fragment slot="head">
    <title th:text="|#{page.categories.title} - ${site.title}|"></title>
  </Fragment>

  <section class="card-base onload-animation mb-4 px-6 py-6 md:px-9">
    <div class="min-w-0">
      <h1
        class="relative mb-2 text-3xl font-bold text-90 before:absolute before:-left-4.5 before:top-3 before:h-5 before:w-1 before:rounded-md before:bg-(--primary) md:text-4xl"
        th:text="#{page.categories.title}"
      >
        分类
      </h1>
      <div class="mb-6 flex flex-wrap items-center gap-1.5 text-sm">
        <span
          class="icon-[material-symbols--folder-open-rounded] text-base text-(--primary)"
        ></span>
        <span class="font-bold text-(--primary)">文章分类</span>
        <span class="text-30">·</span>
        <span
          th:if="${categories != null}"
          th:text="${'共 ' + #lists.size(categories) + ' 个分类'}"
          class="text-50">0 个分类</span
        >
      </div>
    </div>
  </section>
</MainGridLayout>
<div class="grid gap-3 sm:grid-cols-2">
  <a
    th:each="category : ${categories}"
    th:href="@{${category.status.permalink}}"
    class="btn-card btn-card-outline card-tilt group min-h-24 justify-between! rounded-2xl px-5 py-4 text-left"
  >
    <div>
      <div
        class="text-xl font-bold text-90 transition group-hover:text-(--primary)"
        th:text="${category.spec.displayName}"
      >
        Category
      </div>
      <div
        class="mt-1 text-sm text-50"
        th:if="${not #strings.isEmpty(category.spec.description)}"
        th:text="${category.spec.description}"
      >
      </div>
    </div>
    <span
      class="rounded-lg bg-(--btn-regular-bg) px-2 py-1 text-sm font-bold text-(--btn-content)"
      th:text="${category.postCount ?: 0}">0</span
    >
  </a>
</div>
