---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import CopyButton from "../components/CopyButton.astro";
import "../styles/link-submit-modal.css";
---

<MainGridLayout title="${linksTitle + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${linksTitle + ' - ' + site.title}"></title>
    <style is:global>
      .collapse-icon.is-expanded {
        transform: rotate(180deg);
      }
      .collapse-inner ul,
      .step-desc ul {
        list-style: disc;
        padding-left: 1.25rem;
      }
      .collapse-inner ol,
      .step-desc ol {
        list-style: decimal;
        padding-left: 1.25rem;
      }
      .collapse-inner a,
      .step-desc a {
        color: var(--primary);
        text-decoration: underline;
      }
    </style>
  </Fragment>

  <section class="card-base onload-animation mb-4 px-6 py-6 md:px-9">
    <div
      class="mb-6 flex flex-col items-start gap-3 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <h1 class="text-3xl font-bold text-90" th:text="${linksTitle}">
          友情链接
        </h1>
        <div class="mt-1 text-sm text-50">
          <span class="icon-[material-symbols--link-rounded] mr-1"></span>
          <span>Friends links</span>
        </div>
      </div>
      <button
        th:if="${theme.config?.links?.features?.enable_random_visit != false && not #lists.isEmpty(groups)}"
        type="button"
        id="random-visit-btn"
        th:attr="data-random-groups=${theme.config?.links?.features?.random_visit_groups}"
        class="random-visit-btn btn-regular h-11 w-fit rounded-lg px-4 text-sm font-bold active:scale-95"
        title="随机访问一个友链"
      >
        <span
          class="icon-[material-symbols--shuffle-outline-rounded] mr-1.5 text-base"
        ></span>
        <span>随机访问</span>
      </button>
    </div>

    <div
      th:if="${not #lists.isEmpty(groups)}"
      class="mb-6 flex flex-wrap gap-2"
    >
      <a
        th:href="@{/links}"
        th:classappend="${#lists.isEmpty(param.group) ? ' bg-(--primary) text-white dark:text-black/70' : ''}"
        class="btn-card h-9 rounded-lg px-3 text-sm font-bold text-75"
        th:text="#{common.all}">全部</a
      >
      <a
        th:each="group : ${groups}"
        th:if="${not #lists.isEmpty(group.links)}"
        th:href="@{/links(group=${group.spec.displayName})}"
        th:classappend="${#lists.contains(param.group, group.spec.displayName) ? ' bg-(--primary) text-white dark:text-black/70' : ''}"
        class="btn-card h-9 rounded-lg px-3 text-sm font-bold text-75"
      >
        <span th:text="${group.spec.displayName}">Group</span>
        <span class="ml-1 text-30" th:text="${#lists.size(group.links)}">0</span
        >
      </a>
    </div>

    <div th:if="${not #lists.isEmpty(groups)}" class="space-y-8">
      <section
        th:each="group, groupStat : ${groups}"
        th:if="${(#lists.isEmpty(param.group) or #lists.contains(param.group, group.spec.displayName)) and not #lists.isEmpty(group.links)}"
        th:style="|animation-delay: calc(var(--content-delay) + ${groupStat.index * 50}ms)|"
        class="onload-animation"
      >
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-xl font-bold text-90">
            <span th:text="${group.spec.displayName}">Group</span>
          </h2>
          <span
            class="rounded-lg bg-(--btn-regular-bg) px-2.5 py-1 text-xs font-bold text-(--btn-content)"
            th:text="${#lists.size(group.links)}">0</span
          >
        </div>
        <div
          class="grid gap-4 grid-cols-[repeat(auto-fill,minmax(min(220px,100%),1fr))]"
        >
          <a
            th:each="link, linkStat : ${group.links}"
            th:href="${link.spec.url}"
            th:title="${link.spec.displayName}"
            th:attr="data-link-group=${group.spec.displayName}"
            th:style="|animation-delay: calc(var(--content-delay) + ${(groupStat.index * 4 + linkStat.index) * 35}ms)|"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-card btn-card-outline card-tilt group min-h-28 items-start! justify-start! gap-4 rounded-xl p-4 text-left active:scale-95"
          >
            <img
              alt=""
              th:if="${not #strings.isEmpty(link.spec.logo)}"
              th:src="${link.spec.logo}"
              th:alt="${link.spec.displayName}"
              loading="lazy"
              class="h-12 w-12 shrink-0 rounded-xl bg-(--btn-regular-bg) object-cover transition group-hover:scale-105"
            />
            <div
              th:unless="${not #strings.isEmpty(link.spec.logo)}"
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-(--btn-regular-bg) text-(--primary)"
            >
              <span class="icon-[material-symbols--link-rounded] text-2xl"
              ></span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-start gap-2">
                <div
                  class="min-w-0 flex-1 truncate text-base font-bold text-90 transition group-hover:text-(--primary)"
                  th:text="${link.spec.displayName}"
                >
                  Link
                </div><span
                  class="icon-[fa6-solid--arrow-up-right-from-square] mt-0.5 shrink-0 text-sm text-30 transition group-hover:text-(--primary)"
                ></span>
              </div>
              <div
                th:if="${not #strings.isEmpty(link.spec.description)}"
                class="mt-1 line-clamp-2 text-sm leading-6 text-50"
                th:text="${link.spec.description}"
              >
                Description
              </div>
              <div
                class="mt-2 truncate text-xs font-medium text-30"
                th:text="${link.spec.url}"
              >
                https://example.com
              </div>
            </div>
          </a>
        </div>
      </section>
    </div>

    <div th:if="${#lists.isEmpty(groups)}" class="py-12 text-center text-50">
      暂无友情链接
    </div>
  </section>

  <!-- 我的博客信息 + 申请友链 + 折叠面板 -->
  <div class="card-base onload-animation mb-4 px-6 py-6 md:px-9">
    <div class="mb-5 grid grid-cols-1 gap-4 lg:grid-cols-2">
      <!-- 左卡片：我的博客信息 -->
      <div
        class="rounded-xl border p-4"
        style="border-color: color-mix(in oklab, var(--primary) 18%, transparent)"
      >
        <div class="flex items-center gap-3">
          <img
            th:if="${not #strings.isEmpty(theme.config?.links?.ownerInfo.owner_avatar)}"
            th:src="${theme.config?.links?.ownerInfo.owner_avatar}"
            th:alt="${theme.config?.links?.ownerInfo.owner_name}"
            class="h-14 w-14 shrink-0 rounded-xl object-cover"
          />
          <div
            th:unless="${not #strings.isEmpty(theme.config?.links?.ownerInfo.owner_avatar)}"
            class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-(--btn-regular-bg) text-(--primary)"
          >
            <span class="icon-[material-symbols--link-rounded] text-2xl"></span>
          </div>
          <div class="min-w-0 flex-1">
            <h3
              class="text-base font-bold text-90"
              th:text="${theme.config?.links?.ownerInfo.owner_name}"
            >
              博客名称
            </h3>
            <p
              class="mt-0.5 line-clamp-2 text-[13px] text-50"
              th:text="${theme.config?.links?.ownerInfo.owner_description}"
            >
              博客描述
            </p>
          </div>
        </div>
        <div class="mt-4 space-y-1.5">
          <div
            class="flex items-center justify-between gap-2 rounded-lg bg-(--btn-regular-bg) p-2"
          >
            <div class="min-w-0 flex-1">
              <div class="text-[11px] text-50">站点名称</div><div
                class="truncate text-[13px] text-90"
                th:text="${theme.config?.links?.ownerInfo.owner_name}"
              >
                博客名称
              </div>
            </div><CopyButton
              copyText="${theme.config?.links?.ownerInfo.owner_name}"
            />
          </div>
          <div
            class="flex items-center justify-between gap-2 rounded-lg bg-(--btn-regular-bg) p-2"
          >
            <div class="min-w-0 flex-1">
              <div class="text-[11px] text-50">站点描述</div><div
                class="line-clamp-2 text-[13px] text-90"
                th:text="${theme.config?.links?.ownerInfo.owner_description}"
              >
                博客描述
              </div>
            </div><CopyButton
              copyText="${theme.config?.links?.ownerInfo.owner_description}"
            />
          </div>
          <div
            class="flex items-center justify-between gap-2 rounded-lg bg-(--btn-regular-bg) p-2"
          >
            <div class="min-w-0 flex-1">
              <div class="text-[11px] text-50">站点链接</div><div
                class="truncate text-[13px] text-90"
                th:text="${theme.config?.links?.ownerInfo.owner_url}"
              >
                https://example.com
              </div>
            </div><CopyButton
              copyText="${theme.config?.links?.ownerInfo.owner_url}"
            />
          </div>
          <div
            class="flex items-center justify-between gap-2 rounded-lg bg-(--btn-regular-bg) p-2"
          >
            <div class="min-w-0 flex-1">
              <div class="text-[11px] text-50">头像链接</div><div
                class="truncate text-[13px] text-90"
                th:text="${theme.config?.links?.ownerInfo.owner_avatar}"
              >
                https://example.com/avatar.jpg
              </div>
            </div><CopyButton
              copyText="${theme.config?.links?.ownerInfo.owner_avatar}"
            />
          </div>
          <div
            class="flex items-center justify-between gap-2 rounded-lg bg-(--btn-regular-bg) p-2"
          >
            <div class="min-w-0 flex-1">
              <div class="text-[11px] text-50">RSS 地址</div><div
                class="truncate text-[13px] text-90"
                th:text="${theme.config?.links?.ownerInfo.owner_rss}"
              >
                /rss.xml
              </div>
            </div><CopyButton
              copyText="${theme.config?.links?.ownerInfo.owner_rss}"
            />
          </div>
        </div>
      </div>

      <!-- 右卡片：申请友链流程 -->
      <th:block
        th:with="applySteps=${theme.config?.links?.['applyFlow']?.applySteps}"
      >
        <div
          class="flex flex-col rounded-xl border p-4"
          style="border-color: color-mix(in oklab, var(--primary) 18%, transparent)"
        >
          <h3
            class="mb-4 mt-1 flex items-center gap-2 text-base font-bold text-90"
          >
            <span
              class="icon-[material-symbols--fact-check-outline-rounded] text-xl text-(--primary)"
            ></span>申请友链
          </h3>
          <div
            th:if="${applySteps != null and not #lists.isEmpty(applySteps)}"
            class="space-y-5"
          >
            <div
              th:each="step, stepStat : ${applySteps}"
              class="relative flex items-start gap-3"
            >
              <div
                class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--primary) text-xs font-bold text-white"
                th:text="${stepStat.index + 1}"
              >
                1
              </div>
              <div
                th:unless="${stepStat.last}"
                class="absolute left-[11px] top-7 bottom-[-1rem] w-0.5 bg-black/10 dark:bg-white/10"
              >
              </div>
              <div class="min-w-0 flex-1">
                <h4
                  class="text-[13px] font-medium text-90"
                  th:text="${step.title}"
                >
                  步骤标题
                </h4><div
                  class="step-desc mt-0.5 text-xs text-50"
                  th:utext="${step.desc}"
                >
                  步骤说明
                </div>
              </div>
            </div>
          </div>
          <!-- 默认申请流程（新安装未保存设置时显示） -->
          <div
            th:if="${applySteps == null or #lists.isEmpty(applySteps)}"
            class="space-y-5"
          >
            <div class="relative flex items-start gap-3">
              <div
                class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--primary) text-xs font-bold text-white"
              >
                1
              </div>
              <div
                class="absolute left-[11px] top-7 bottom-[-1rem] w-0.5 bg-black/10 dark:bg-white/10"
              >
              </div>
              <div class="min-w-0 flex-1">
                <h4 class="text-[13px] font-medium text-90">添加本站友链</h4>
                <div class="step-desc mt-0.5 text-xs text-50">
                  请先在您的网站友链页面<strong>添加本站信息</strong
                  >，可直接复制左侧各字段
                </div>
              </div>
            </div>
            <div class="relative flex items-start gap-3">
              <div
                class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--primary) text-xs font-bold text-white"
              >
                2
              </div>
              <div
                class="absolute left-[11px] top-7 bottom-[-1rem] w-0.5 bg-black/10 dark:bg-white/10"
              >
              </div>
              <div class="min-w-0 flex-1">
                <h4 class="text-[13px] font-medium text-90">评论留言</h4>
                <div class="step-desc mt-0.5 text-xs text-50">
                  在本页下方评论区留言提交申请
                </div>
              </div>
            </div>
            <div class="relative flex items-start gap-3">
              <div
                class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--primary) text-xs font-bold text-white"
              >
                3
              </div>
              <div class="min-w-0 flex-1">
                <h4 class="text-[13px] font-medium text-90">等待审核</h4>
                <div class="step-desc mt-0.5 text-xs text-50">
                  确认信息无误后会尽快添加您的友链
                </div>
              </div>
            </div>
          </div>
        </div>
      </th:block>
    </div>

    <!-- 折叠面板 -->
    <th:block
      th:with="accs=${theme.config?.links?.['accordionPanel']?.accordions}"
    >
      <div
        th:if="${accs != null and not #lists.isEmpty(accs)}"
        class="space-y-2"
        id="links-accordion"
      >
        <div
          th:each="item, itemStat : ${accs}"
          class="collapse-item rounded-xl bg-(--btn-regular-bg)"
        >
          <button
            type="button"
            class="collapse-header flex w-full items-center justify-between p-3 text-left transition"
            th:attr="data-collapse-target='accordion-'+${itemStat.index}"
          >
            <div class="flex items-center gap-2">
              <span
                class="text-lg text-(--primary)"
                th:if="${item.icon != null && item.icon.value != null}"
                th:utext="${item.icon.value}"></span><span
                class="text-sm font-medium text-90"
                th:text="${item.title}">面板标题</span
              >
            </div>
            <span
              class="collapse-icon icon-[material-symbols--expand-more-rounded] text-lg text-50 transition-transform duration-200"
            ></span>
          </button>
          <div
            th:attr="id='accordion-'+${itemStat.index}"
            class="collapse-content"
          >
            <div class="collapse-inner px-3 pb-3">
              <div
                class="text-sm text-50 leading-relaxed"
                th:utext="${item.content}"
              >
                正文
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- 默认折叠面板（新安装未保存设置时显示） -->
      <div
        th:if="${accs == null or #lists.isEmpty(accs)}"
        class="space-y-2"
        id="links-accordion"
      >
        <div class="collapse-item rounded-xl bg-(--btn-regular-bg)">
          <button
            type="button"
            class="collapse-header flex w-full items-center justify-between p-3 text-left transition"
            data-collapse-target="accordion-0"
          >
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-90">友链须知</span>
            </div>
            <span
              class="collapse-icon icon-[material-symbols--expand-more-rounded] text-lg text-50 transition-transform duration-200"
            ></span>
          </button>
          <div id="accordion-0" class="collapse-content">
            <div class="collapse-inner px-3 pb-3">
              <div class="text-sm text-50 leading-relaxed">
                <ul>
                  <li>请先在您的网站添加本站信息</li><li>
                    网站能够正常访问，使用HTTPS
                  </li><li>网站符合中国大陆法律法规</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
        <div class="collapse-item rounded-xl bg-(--btn-regular-bg)">
          <button
            type="button"
            class="collapse-header flex w-full items-center justify-between p-3 text-left transition"
            data-collapse-target="accordion-1"
          >
            <div class="flex items-center gap-2">
              <span class="text-sm font-medium text-90">免责申明</span>
            </div>
            <span
              class="collapse-icon icon-[material-symbols--expand-more-rounded] text-lg text-50 transition-transform duration-200"
            ></span>
          </button>
          <div id="accordion-1" class="collapse-content">
            <div class="collapse-inner px-3 pb-3">
              <div class="text-sm text-50 leading-relaxed">
                <ul>
                  <li>
                    本博客严格遵守中华人民共和国法律法规，友情链接及其他外链，仅为了方便学习与交流而收集整理
                  </li><li>
                    本人能力有限，无法逐一甄别每篇文章的全部内容，也无法实时跟进并确认原作者后续是否对链接内容进行篡改，包括但不限于发布违法信息、植入恶意代码、诱导点击或破坏用户计算机等行为
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </th:block>
  </div>

  <script
    src={`${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/requirements.js`}
    defer></script>
  <script
    src={`${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/random-visit.js`}
    defer></script>
  <script
    src={`${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/collapse.js`}
    defer></script>
  <script
    src={`${import.meta.env.BASE_URL.replace(/\/+$/, "")}/assets/copy.js`}
    defer></script>

  <div
    id="comment"
    th:if="${haloCommentEnabled && (theme.config?.links?.features.enable_comment == null || theme.config?.links?.features.enable_comment)}"
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="plugin.halo.run" kind="Plugin" th:attr="name=${pluginName}" />'}
    />
  </div>
</MainGridLayout>
